# ───── Database (Neon Postgres) ─────
# Pooler URL for runtime queries
DATABASE_URL="postgresql://USER:PASS@ep-XXX-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct (non-pooler) URL for migrations
DIRECT_URL="postgresql://USER:PASS@ep-XXX.REGION.aws.neon.tech/DB?sslmode=require"

# ───── Auth / session ─────
SESSION_SECRET="REPLACE-WITH-A-LONG-RANDOM-STRING-AT-LEAST-32-CHARS"
NEXT_PUBLIC_URL="http://localhost:3011"

# ───── Email (Resend) ─────
# Get one at https://resend.com/api-keys
RESEND_API_KEY=""

# ───── Stripe (optional — checkout returns 500 without these) ─────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_TEAM_PRICE_ID=""
STRIPE_INTRO_COUPON_ID=""

# ───── Platform OAuth ─────
# Each one falls back to a sandbox connect flow when blank.

# X (Twitter) — developer.x.com
# Callback: <NEXT_PUBLIC_URL>/api/auth/oauth/twitter/callback
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# Meta (Instagram via Facebook Login) — developers.facebook.com
# Callback: <NEXT_PUBLIC_URL>/api/auth/oauth/instagram/callback
# Requires Instagram Business/Creator account linked to a Facebook Page
META_APP_ID=""
META_APP_SECRET=""

# TikTok — developers.tiktok.com
# Callback: <NEXT_PUBLIC_URL>/api/auth/oauth/tiktok/callback
# Production direct-post requires TikTok app review
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# ───── Cron auth (optional — for /api/cron/run-due) ─────
CRON_SECRET=""
